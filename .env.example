# このファイルを .env にコピーして値を設定してください。
# .env は絶対にコミットしないこと（.gitignore 済み）。

# --- Gmail 送信（必須） ---
# 送信元の Gmail アドレス
GMAIL_ADDRESS=your_account@gmail.com
# Gmail のアプリパスワード（16桁）。通常のログインパスワードではありません。
# 2段階認証を有効にして https://myaccount.google.com/apppasswords で発行。
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# 送信先（省略時は GMAIL_ADDRESS 宛て）
MAIL_TO=your_account@gmail.com
# 送信元表示（省略時は GMAIL_ADDRESS）
MAIL_FROM=

# --- 要約に Claude を使う場合（任意） ---
# 未設定ならRSSの概要をそのまま短縮して使用します。
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- 挙動の調整（任意） ---
# 対象とする記事の新しさ（時間）
MAX_AGE_HOURS=24
# 1回のメールに含める最大件数
MAX_ARTICLES=10
# RSSフィード（カンマ区切り。未設定ならデフォルトのBloombergフィード）
BLOOMBERG_RSS_FEEDS=
# 金利キーワード（カンマ区切り。未設定なら組み込みキーワード）
RATE_KEYWORDS=
# 送信済み記録ファイル
STATE_FILE=sent_articles.json
